<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.aws-vpn-watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>SCRIPT_PATH_PLACEHOLDER</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>STDOUT_LOG_PLACEHOLDER</string>
    <key>StandardErrorPath</key>
    <string>STDERR_LOG_PLACEHOLDER</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/sbin</string>
        <key>HOME</key>
        <string>HOME_PLACEHOLDER</string>
        <key>AWS_CONFIG_FILE</key>
        <string>HOME_PLACEHOLDER/.aws/config</string>
        <key>AWS_SHARED_CREDENTIALS_FILE</key>
        <string>HOME_PLACEHOLDER/.aws/credentials</string>
    </dict>
</dict>
</plist>
